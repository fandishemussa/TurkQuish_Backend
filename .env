APP_ENV=development
API_PREFIX=/api/v1
ARTIFACT_DIR=app/artifacts
DATABASE_URL=sqlite:///./turkquish.db
CORS_ORIGINS=*
URL_HASH_SALT=change-me-in-production
ENABLE_URL_TRANSFORMER=true
HISTGB_CONFIDENCE_THRESHOLD=0.80
HISTGB_MARGIN_THRESHOLD=0.20
RISK_BOUNDARY_LOW=0.40
RISK_BOUNDARY_HIGH=0.60
MAX_URL_LENGTH=4096
ENABLE_RATE_LIMITING=false
RATE_LIMIT_REQUESTS_PER_MINUTE=100000
